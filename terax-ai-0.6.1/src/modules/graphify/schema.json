{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GraphModuleSchema",
  "type": "object",
  "required": [
    "data",
    "interaction",
    "viewport"
  ],
  "properties": {
    "data": {
      "$ref": "#/definitions/GraphData"
    },
    "viewport": {
      "$ref": "#/definitions/ViewportState"
    },
    "interaction": {
      "$ref": "#/definitions/InteractionState"
    }
  },
  "definitions": {
    "GraphData": {
      "type": "object",
      "required": [
        "edges",
        "metadata",
        "nodes"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GraphNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GraphEdge"
          }
        },
        "metadata": {
          "$ref": "#/definitions/GraphMetadata"
        }
      }
    },
    "GraphNode": {
      "type": "object",
      "required": [
        "filePath",
        "id",
        "label",
        "size",
        "type",
        "x",
        "y"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "filePath": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/NodeType"
        },
        "x": {
          "type": "number",
          "format": "double"
        },
        "y": {
          "type": "number",
          "format": "double"
        },
        "size": {
          "type": "number",
          "format": "float"
        }
      }
    },
    "NodeType": {
      "type": "string",
      "enum": [
        "file",
        "function",
        "class",
        "interface",
        "export"
      ]
    },
    "GraphEdge": {
      "type": "object",
      "required": [
        "source",
        "target",
        "type",
        "weight"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/EdgeType"
        },
        "weight": {
          "type": "number",
          "format": "float"
        }
      }
    },
    "EdgeType": {
      "type": "string",
      "enum": [
        "import",
        "export",
        "extends",
        "implements",
        "calls"
      ]
    },
    "GraphMetadata": {
      "type": "object",
      "required": [
        "generatedAt",
        "rootDirectory",
        "totalEdges",
        "totalNodes"
      ],
      "properties": {
        "totalNodes": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "totalEdges": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "rootDirectory": {
          "type": "string"
        },
        "generatedAt": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "ViewportState": {
      "type": "object",
      "required": [
        "pan",
        "zoom"
      ],
      "properties": {
        "zoom": {
          "type": "number",
          "format": "double"
        },
        "pan": {
          "$ref": "#/definitions/Point"
        }
      }
    },
    "Point": {
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number",
          "format": "double"
        },
        "y": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "InteractionState": {
      "type": "object",
      "properties": {
        "selectedNodeId": {
          "type": [
            "string",
            "null"
          ]
        },
        "hoveredNodeId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}